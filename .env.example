# Copy this file to .env and fill in your values
# cp .env.example .env

# Oura Ring API (Personal Access Token from cloud.ouraring.com/personal-access-tokens)
OURA_TOKEN=your_oura_personal_access_token_here

# OpenWeatherMap API (free tier, from openweathermap.org/api)
OPENWEATHERMAP_KEY=your_openweathermap_api_key_here

# Location coordinates for weather data
WEATHER_LAT=39.9526  # Example: Philadelphia, PA
WEATHER_LON=-75.1652

# Optional: GitHub Personal Access Token (for GitHub activity assets)
# Only needed if you want to track your own GitHub commit activity
# Requires: repo (read) scope
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username
